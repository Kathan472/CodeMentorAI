# ============================================================
# CodeMentor AI — Environment Variables
# ============================================================
# Copy this file to `.env` and fill in your own values.
# NEVER commit your real .env file to version control.
# ============================================================

# --- Database (MySQL / TiDB Cloud) ---
# Format: mysql+mysqlconnector://user:password@host:port/dbname
DATABASE_URL=mysql+mysqlconnector://your_user:your_password@your_host:4000/your_db

# --- Gemini API (Primary AI provider — free tier available) ---
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Optional: NVIDIA API (fallback AI provider) ---
# Get yours at: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here

# --- Optional: OpenRouter API (fallback AI provider — gives access to many models) ---
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- Authentication (JWT) ---
# IMPORTANT: Change this to a long, random string in production!
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_this_to_a_random_secret_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=168   # 7 days

# --- Server ---
ENVIRONMENT=development
DEBUG=True
